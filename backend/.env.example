# PostgreSQL connection string (Render provides this automatically when linked)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# JWT secret — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# Comma-separated frontend origins (Netlify URL + local dev)
# Production API: https://gharseva-mcpc.onrender.com
# Production frontend: https://charming-horse-0b7ee8.netlify.app
CORS_ORIGINS="http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,https://charming-horse-0b7ee8.netlify.app"

PORT=4000
NODE_ENV=development
